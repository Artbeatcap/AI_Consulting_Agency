# ── PocketBase ───────────────────────────────────────────────────────────────
# URL of your running PocketBase instance (used by the frontend for auth + API calls)
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# ── GHL / GrowthHub365 ────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — set these as environment variables on your PocketBase
# server/host. Do NOT prefix with VITE_ or they will be exposed in the browser.
#
# Step 1: In GHL, create a Workflow → Inbound Webhook trigger.
# Step 2: Copy the webhook URL and set it below (on the server, not here).
# Step 3: Add a "Create/Update Contact" action and map:
#           firstName  → First Name
#           lastName   → Last Name
#           email      → Email
#           phone      → Phone
#           company    → Company Name
#           message    → Notes / custom field
#           howDidYouHear → custom field (or Notes)
#           source     → Lead Source
#
# GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_HOOK_ID/webhook-trigger/...
#
# Optional: map "howDidYouHear" to a GHL custom field by ID
# GHL_CUSTOM_FIELD_HOW_DID_YOU_HEAR_ID=your_custom_field_id_here
